<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- clear discards any machine-wide or user-wide sources (including
         broken ones like the Visual Studio offline package folder), so
         restore only ever uses nuget.org. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!-- This section is separate from packageSources above, and MSBuild's
       package-resolution tasks (used by "dotnet build", "dotnet ef", etc.)
       check it independently, even after a successful restore. Without
       clearing it too, an inherited broken fallback folder from a machine-
       wide config still crashes builds. -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>

  <packageRestore>
    <add key="enabled" value="true" />
  </packageRestore>
</configuration>
